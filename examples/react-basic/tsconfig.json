{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "exactOptionalPropertyTypes": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*", "src/vite-env.d.ts"]
}
