{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": false,
    "declarationMap": false,
    "outDir": "dist-test",
    "rootDir": ".",
    "noEmit": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["test/**/*.ts", "test/**/*.tsx", "src/plugins.ts"],
  "exclude": []
}
