{
  "name": "@aether-md/react",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/linshuohao/AetherMD.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test $(find dist-test -name '*.test.js' | sort)",
    "check": "pnpm typecheck && pnpm test",
    "types:check": "tsd --typings dist/index.d.ts"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "dependencies": {
    "@aether-md/core": "workspace:*",
    "@aether-md/plugin-prosemirror": "workspace:*"
  },
  "devDependencies": {
    "@aether-md/plugin-remark": "workspace:*",
    "@aether-md/preset-gfm": "workspace:*",
    "@happy-dom/global-registrator": "^17.4.7",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "happy-dom": "^17.4.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^6.0.3"
  }
}
