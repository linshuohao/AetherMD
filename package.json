{
  "name": "aether-md",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "check": "pnpm skills:check && pnpm workflow:pr-check && pnpm lint && pnpm format:check && pnpm docs:check-links && turbo run check && turbo run types:check",
    "bench:morphing": "pnpm --filter @aether-md/preset-gfm... build && node scripts/bench-morphing.mjs",
    "types:check": "turbo run types:check",
    "docs:check-links": "node scripts/check-markdown-links.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "changeset:status": "changeset status --since main",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "skills:sync": "node scripts/sync-aether-workflow-skills.mjs",
    "skills:check": "node scripts/check-aether-workflow-skills.mjs",
    "workflow:pr-check": "node scripts/check-workflow-pr-traceability.mjs -- /dev/null",
    "lint:commits": "commitlint --config .commitlintrc.cjs --from origin/main --to HEAD --verbose",
    "lint:pr-title": "commitlint --config .commitlintrc.cjs --verbose",
    "ruleset:apply": "node scripts/apply-github-ruleset.mjs",
    "core:build": "pnpm --filter @aether-md/core build",
    "core:typecheck": "pnpm --filter @aether-md/core exec tsc --noEmit",
    "core:test": "pnpm --filter @aether-md/core test",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:test": "playwright test --config e2e/playwright/playwright.config.ts",
    "e2e:test:headed": "playwright test --config e2e/playwright/playwright.config.ts --project=chromium --headed",
    "e2e:test:ui": "playwright test --config e2e/playwright/playwright.config.ts --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.54.0",
    "tsd": "^0.31.2",
    "vitest": "^3.2.4"
  }
}
